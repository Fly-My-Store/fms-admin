# Fly My Store Admin — environment template (committed).
#
# SERVER (PM2 / aaPanel): use `.env` in project root — npm run build && npm run start read it automatically.
#
# LOCAL (optional): copy into envs/ for multi-env dev:
#   npm run env:init              → envs/local.env
#   npm run env:init -- production
#   npm run dev                   → uses envs/local.env (dotenv-cli, devDependency)

NEXT_PUBLIC_VERSION=v3.4.0
GENERATE_SOURCEMAP=false

NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1/
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

NEXT_PUBLIC_AUTH_URL=http://localhost:3001/
NEXT_PUBLIC_NEXTAUTH_SECRET=change_me
NEXT_PUBLIC_JWT_TIMEOUT=86400
NEXT_PUBLIC_JWT_SECRET=change_me
